{
	"name":                 "wpsp-vue",
	"version":              "13.1.12",
	"description":          "",
	"author":               "OceanCodex",
	"license":              "GPL-2.0-or-later",
	"main":                 "index.js",
	"directories":          {
		"test": "tests"
	},
	"$schema":              "https://www.schemastore.org/package.json",
	"private":              true,
	"type":                 "module",
	"scripts":              {
		"live-reload":            "node ./public/node/server.js",
		"vite-dev":               "npm run vue-dev",
		"vite-build":             "vite build --config vite.config.mjs",
		"vite-watch":             "vite build --watch --config vite.config.mjs",
		"vite-preview":           "vite preview --config vite.config.mjs",
		"vue-dev":                "vite --config vite.config.js",
		"vue-build":              "vite build --config vite.config.js",
		"vue-build:ssr":          "vite build --config vite.config.js && vite build --ssr --config vite.config.js",
		"vue-types:check":        "vue-tsc --noEmit",
		"prettier-format":        "prettier --write resources/",
		"prettier-format:check":  "prettier --check resources/",
		"eslint":                 "eslint . --fix",
		"eslint:check":           "eslint .",
		"mix":                    "mix",
		"mix-watch":              "mix watch",
		"mix-watch-production":   "mix --production -- --watch --progress",
		"mix-watch-poll":         "mix watch -- --watch-options-poll=1000",
		"mix-watch-hot":          "mix watch --hot",
		"mix-production":         "mix --production",
		"blocks-build":           "wp-scripts build --webpack-copy-php --blocks-manifest --source-path=./resources/views/blocks/src --output-path=./resources/views/blocks/build",
		"blocks-format":          "wp-scripts format",
		"blocks-lint:css":        "wp-scripts lint-style",
		"blocks-lint:js":         "wp-scripts lint-js",
		"blocks-packages-update": "wp-scripts packages-update",
		"blocks-plugin-zip":      "wp-scripts plugin-zip",
		"blocks-start":           "wp-scripts start --webpack-copy-php --blocks-manifest --source-path=./resources/views/blocks/src --output-path=./resources/views/blocks/build"
	},
	"devDependencies":      {
		"@tailwindcss/vite":                 "^4.3",
		"@types/jquery":                     "^4.0",
		"@types/jqueryui":                   "^1.12",
		"@wordpress/block-editor":           "^15.21",
		"@wordpress/components":             "^35.0",
		"@wordpress/scripts":                "^32.4",
		"chokidar":                          "^5.0",
		"concurrently":                      "^10.0",
		"cross-env":                         "^10.1",
		"glob":                              "^13.0",
		"laravel-mix":                       "^6.0",
		"laravel-vite-plugin":               "^3.1",
		"lodash":                            "^4.18",
		"mini-css-extract-plugin":           "^2.10",
		"postcss":                           "^8.5",
		"resolve-url-loader":                "^5.0",
		"sass":                              "^1.100",
		"sass-loader":                       "^17.0",
		"socket.io":                         "^4.8",
		"tailwindcss":                       "^4.3",
		"ts-loader":                         "^9.6",
		"typescript":                        "^6.0",
		"vite":                              "^8.0",
		"webpack":                           "~5.105",
		"webpack-remove-empty-scripts":      "^1.1",
		"@eslint/js":                        "^9.39",
		"@laravel/vite-plugin-wayfinder":    "^0.1",
		"@stylistic/eslint-plugin":          "^5.10",
		"@types/node":                       "^26.0",
		"@vitejs/plugin-vue":                "^6.0",
		"@vue/eslint-config-typescript":     "^14.8",
		"eslint":                            "^9.39",
		"eslint-config-prettier":            "^10.1",
		"eslint-import-resolver-typescript": "^4.4",
		"eslint-plugin-import":              "^2.32",
		"eslint-plugin-vue":                 "^10.9",
		"prettier":                          "^3.8",
		"prettier-plugin-tailwindcss":       "^0.8",
		"typescript-eslint":                 "^8.61",
		"vue-tsc":                           "^3.3"
	},
	"dependencies":         {
		"@inertiajs/vite":          "^3.4",
		"@inertiajs/vue3":          "^3.4",
		"@vue/server-renderer":     "^3.5",
		"@vueuse/core":             "^14.3",
		"class-variance-authority": "^0.7",
		"clsx":                     "^2.1",
		"laravel-vite-plugin":      "^3.1",
		"lucide-vue-next":          "^1.0",
		"reka-ui":                  "^2.9",
		"tailwind-merge":           "^3.6",
		"tailwindcss":              "^4.3",
		"tw-animate-css":           "^1.4",
		"vue":                      "^3.5",
		"vue-input-otp":            "^0.3",
		"vue-sonner":               "^2.0"
	},
	"overrides":            {
		"yargs": "^18.0"
	},
	"__COMMENTS__":         [
		{
			"overrides.yargs": "Để sử dụng được Laravel Mix với phiên bản Node 26, cần phải cài đặt yargs phiên bản mới nhất!"
		}
	],
	"optionalDependencies": {
		"@rollup/rollup-linux-x64-gnu":      "^4.62",
		"@rollup/rollup-win32-x64-msvc":     "^4.62",
		"@tailwindcss/oxide-linux-x64-gnu":  "^4.3",
		"@tailwindcss/oxide-win32-x64-msvc": "^4.3",
		"lightningcss-linux-x64-gnu":        "^1.32",
		"lightningcss-win32-x64-msvc":       "^1.32"
	}
}